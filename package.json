{
  "name": "xstate-wizards",
  "private": true,
  "description": "Wizards for Complex Data Collection",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "author": "Mark Hansen <x@markthemark.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/youmustfight/xstate-wizards"
  },
  "dependencies": {
    "@manypkg/cli": "^0.21.0",
    "@manypkg/get-packages": "^2.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "lerna": "^8.2.4",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "yalc": "^1.0.0-pre.53"
  },
  "overrides": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0"
  },
  "scripts": {
    "postinstall": "manypkg check || true",
    "clean:packages": "npm run clean --workspaces --if-present",
    "build": "lerna run build",
    "test": "lerna run test",
    "test:examples": "npx playwright test",
    "yalclink": "lerna run yalclink && cd ./examples/react-spellbook && npm run yalclink && cd - && cd ./examples/react-wizards && npm run yalclink && cd - && cd ./examples/react-wizards-i18n && npm run yalclink && cd -",
    "yalcpush": "lerna run yalcpush",
    "yalcpush-since": "lerna run yalcpush --since main"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}