{
  "name": "@xstate-wizards/crystal-ball",
  "version": "1.0.0",
  "author": "Mark Hansen",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist && mkdir dist",
    "build": "npm run clean && tsc -b tsconfig.json",
    "prepublishOnly": "NODE_ENV=production npm run clean && npm run build",
    "major": "npm version major --no-git-tag-version && npm publish",
    "minor": "npm version minor --no-git-tag-version && npm publish",
    "patch": "npm version patch --no-git-tag-version && npm publish",
    "test": "vitest run",
    "test:ci": "vitest run"
  },
  "dependencies": {
    "@xstate-wizards/spells": "^1.0.0",
    "@xstate-wizards/wizards-of-react": "^1.0.0",
    "date-fns": "^2.4.1",
    "lodash": "^4.17.20",
    "react-player": "^2.11.0",
    "styled-components": "^5.2.3",
    "xstate": "^5.28.0",
    "zustand": "^4.5.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.182",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/styled-components": "^5.1.25",
    "react": "^18.0.0",
    "typescript": "^5.5.0"
  }
}
