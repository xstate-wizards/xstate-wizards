{
  "name": "tel-fns",
  "version": "0.0.5",
  "author": "Mark Hansen",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist && mkdir dist",
    "build": "npm run clean && tsc -b tsconfig.json",
    "prepublishOnly": "NODE_ENV=production npm run clean && npm run build",
    "major": "npm version major --no-git-tag-version && npm publish",
    "minor": "npm version minor --no-git-tag-version && npm publish",
    "patch": "npm version patch --no-git-tag-version && npm publish",
    "pre": "npm version prerelease --preid=$USER --no-git-tag-version && npm publish",
    "test": "jest --runInBand --expand --passWithNoTests",
    "test:ci": "jest --runInBand --expand --passWithNoTests",
    "yalcpush": "npm run build && yalc push",
    "yalclink": "echo 'No Links'"
  },
  "dependencies": {
    "google-libphonenumber": "^3.2.30"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.5.0"
  }
}
