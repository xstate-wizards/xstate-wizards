{
  "name": "@xstate-wizards/spells",
  "version": "0.8.16",
  "author": "Mark Hansen",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist && mkdir dist",
    "build": "npm run clean && tsc -b tsconfig.json",
    "prepublishOnly": "NODE_ENV=production npm run clean && npm run build",
    "major": "npm version major --no-git-tag-version && npm publish",
    "minor": "npm version minor --no-git-tag-version && npm publish",
    "patch": "npm version patch --no-git-tag-version && npm publish",
    "pre": "npm version prerelease --preid=$USER --no-git-tag-version && npm publish",
    "test": "jest --runInBand --expand",
    "test:ci": "jest --runInBand --expand",
    "yalcpush": "npm run build && yalc push",
    "yalclink": "echo 'No Links'"
  },
  "dependencies": {
    "acorn": "^8.7.1",
    "date-fns": "^2.4.1",
    "json-logic-js": "^2.0.2",
    "json-schema": "^0.4.0",
    "lodash": "^4.17.20",
    "tel-fns": "^0.0.5",
    "uuid": "^3.3.3",
    "xstate": "^5.28.0",
    "zustand": "^4.5.0",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/json-logic-js": "^1.2.1",
    "@types/json-schema": "^7.0.11",
    "@types/lodash": "^4.14.182",
    "@types/uuid": "^8.3.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.5.0"
  }
}
