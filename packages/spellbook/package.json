{
  "name": "@xstate-wizards/spellbook",
  "version": "1.0.0",
  "author": "Mark Hansen",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "clean": "rm -rf dist && mkdir dist",
    "build": "npm run clean && tsc -b tsconfig.json && cp src/styles.css dist/",
    "prepublishOnly": "NODE_ENV=production npm run clean && npm run build",
    "major": "npm version major --no-git-tag-version && npm publish",
    "minor": "npm version minor --no-git-tag-version && npm publish",
    "patch": "npm version patch --no-git-tag-version && npm publish",
    "test": "vitest run",
    "test:ci": "vitest run"
  },
  "dependencies": {
    "@xstate-wizards/spells": "^2.0.0",
    "@xstate-wizards/wizards-of-react": "^2.0.0",
    "date-fns": "^2.4.1",
    "framer-motion": "^6.4.3",
    "lodash": "^4.17.20",
    "pretty-print-json": "^1.2.5",
    "xstate": "^5.28.0",
    "zustand": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.182",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.0.0",
    "typescript": "^5.5.0"
  }
}
