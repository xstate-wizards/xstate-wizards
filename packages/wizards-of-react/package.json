{
  "name": "@xstate-wizards/wizards-of-react",
  "version": "3.0.0",
  "author": "Mark Hansen",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "clean": "rm -rf dist && mkdir dist",
    "build": "npm run clean && tsc -b tsconfig.json && cp src/styles.css dist/",
    "prepublishOnly": "NODE_ENV=production npm run clean && npm run build",
    "major": "npm version major --no-git-tag-version && npm publish",
    "minor": "npm version minor --no-git-tag-version && npm publish",
    "patch": "npm version patch --no-git-tag-version && npm publish",
    "pre": "npm version prerelease --preid=$USER --no-git-tag-version && npm publish",
    "test": "vitest run",
    "test:ci": "vitest run"
  },
  "dependencies": {
    "@xstate-wizards/spells": "^3.0.0",
    "@xstate/react": "^6.1.0",
    "date-fns": "^2.4.1",
    "lodash": "^4.17.20",
    "react-player": "^2.11.0",
    "react-use": "^17.3.2",
    "tel-fns": "^0.0.5",
    "use-places-autocomplete": "^3.0.0",
    "uuid": "^3.3.3",
    "xstate": "^5.28.0",
    "zustand": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.182",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^8.3.4",
    "react": "^18.0.0",
    "typescript": "^5.5.0"
  }
}
