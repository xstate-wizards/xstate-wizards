{
  "name": "@xstate-wizards/wizards-of-react",
  "version": "0.8.6",
  "author": "Mark Hansen",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist && mkdir dist",
    "build": "npm run clean && tsc -b tsconfig.json",
    "prepublishOnly": "NODE_ENV=production npm run clean && npm run build",
    "major": "npm version major --no-git-tag-version && npm publish",
    "minor": "npm version minor --no-git-tag-version && npm publish",
    "patch": "npm version patch --no-git-tag-version && npm publish",
    "pre": "npm version prerelease --preid=$USER --no-git-tag-version && npm publish",
    "test": "jest --runInBand --expand --passWithNoTests",
    "test:ci": "jest --runInBand --expand --passWithNoTests",
    "yalcpush": "npm run build && yalc push",
    "yalclink": "npx yalc link @xstate-wizards/spells"
  },
  "dependencies": {
    "@xstate-wizards/spells": "^0.8.16",
    "@xstate/react": "^4.1.0",
    "date-fns": "^2.4.1",
    "lodash": "^4.17.20",
    "react-player": "^2.11.0",
    "react-use": "^17.3.2",
    "styled-components": "^5.2.3",
    "tel-fns": "^0.0.5",
    "use-places-autocomplete": "^3.0.0",
    "uuid": "^3.3.3",
    "xstate": "^5.28.0",
    "zustand": "^4.5.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/lodash": "^4.14.182",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/styled-components": "^5.1.25",
    "@types/uuid": "^8.3.4",
    "jest": "^29.7.0",
    "react": "^18.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.5.0"
  }
}
